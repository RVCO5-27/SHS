# Production / preview: API origin (dev uses Vite proxy → /api, no CORS)
# VITE_API_ORIGIN=http://localhost:5000
# Override dev proxy target if the API is not on port 5000:
# VITE_PROXY_TARGET=http://127.0.0.1:5000
# Or point the SPA at a remote API (skips proxy):
# VITE_API_URL=https://your-api.example.com/api

# Admin HTTPS guard: in production builds, admin routes redirect HTTP → HTTPS unless set to false
# VITE_ADMIN_REQUIRE_HTTPS=false

# Optional: npm run dev with HTTPS (self-signed cert warning in browser)
# VITE_LOCAL_HTTPS=true
