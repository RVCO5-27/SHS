# Copy to .env and fill in values. Never commit .env.

PORT=5000
NODE_ENV=development

# MySQL (must match database created from database/shs.sql or your schema)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=shs

# JWT — in production use a long random string (32+ characters)
JWT_SECRET=change-me-in-development-only

# CORS — Vite dev origin(s); comma-separate for multiple (default allows 5173 and 5174)
# FRONTEND_ORIGIN=http://localhost:5173

# Recovery emails (optional — without SMTP, link is logged to server console in dev)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@deped.gov.ph
